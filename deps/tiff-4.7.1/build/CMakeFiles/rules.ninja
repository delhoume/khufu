rule RERUN_CMAKE
  command = C:\Strawberry\c\bin\cmake.exe --regenerate-during-build -SC:\Users\FredericDelhoume\gitperso\khufu\deps\tiff-4.7.1 -BC:\Users\FredericDelhoume\gitperso\khufu\deps\tiff-4.7.1\build
  description = Re-running CMake...
